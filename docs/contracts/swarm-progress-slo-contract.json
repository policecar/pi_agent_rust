{
  "schema": "pi.swarm.progress_slo_contract.v1",
  "progress_slo_schema": "pi.swarm.progress_slo.v1",
  "contract_version": "1.0.0",
  "bead_id": "bd-wzri8.1",
  "parent_bead_id": "bd-wzri8",
  "purpose": "read_only_swarm_progress_slo_advisory_not_source_of_truth",
  "summary": "Defines the source inventory and evidence contract for a read-only swarm progress SLO. The signal helps operators distinguish useful forward progress, coordination degradation, build saturation, stalled work, and no-open-work convergence; it must not mutate or replace Beads, Agent Mail, RCH, the validation broker, Doctor, runpacks, context intelligence, CI, UBS, release gates, or direct operator judgment.",
  "non_goals": [
    "replace_beads_as_issue_status_or_dependency_source",
    "replace_agent_mail_as_coordination_or_reservation_source",
    "replace_rch_or_validation_broker_as_build_and_validation_authority",
    "replace_doctor_runpacks_autopilot_or_context_intelligence",
    "replace_ci_ubs_beads_ledger_reconciliation_or_release_gates",
    "perform_live_mutation_or_automatic_claiming",
    "claim_release_performance_throughput_or_dropin_certification",
    "infer_missing_progress_facts_without_degraded_uncertainty",
    "emit_unredacted_prompts_tokens_credentials_mail_bodies_or_private_paths"
  ],
  "required_progress_top_level_keys": [
    "schema",
    "generated_at",
    "contract_version",
    "time_window",
    "status",
    "confidence",
    "reason_ids",
    "source_statuses",
    "progress_metrics",
    "saturation_summary",
    "redaction_summary",
    "suppressed_claims",
    "next_actions"
  ],
  "source_inventory_contract": {
    "required_source_ids": [
      "beads_active_delta",
      "beads_closed_delta",
      "git_commit_delta",
      "rch_posture",
      "validation_broker_posture",
      "agent_mail_health",
      "operator_runpack_summary",
      "swarm_autopilot_summary",
      "context_intelligence_summary",
      "operator_time_window"
    ],
    "required_source_classes": [
      "beads_active_closed_delta",
      "git_commit_delta",
      "rch_and_validation_broker_posture",
      "agent_mail_health",
      "runpack_autopilot_context_summaries",
      "operator_provided_time_window"
    ],
    "required_source_fields": [
      "source_id",
      "source_class",
      "source_kind",
      "path",
      "availability",
      "freshness_state",
      "observed_at_utc",
      "source_hash",
      "authoritative_for",
      "redaction_state",
      "degraded_reasons",
      "suppressed_claims"
    ],
    "allowed_availability": [
      "available",
      "unavailable",
      "partial",
      "malformed",
      "stale",
      "not_configured"
    ],
    "allowed_freshness_states": [
      "current",
      "stale",
      "missing",
      "malformed",
      "freshness_unknown"
    ],
    "missing_or_malformed_source_policy": "Missing, unavailable, partial, stale, malformed, or freshness_unknown source rows must remain explicit in source_statuses. The evaluator must not infer progress facts from absent authority. Statuses that depend on missing authority must become coordination_degraded, build_saturated, stalled, malformed_source_degraded, or insufficient_evidence_degraded; they must not become progressing.",
    "minimum_required_authority_for_progressing": [
      "operator_time_window",
      "beads_active_delta",
      "beads_closed_delta",
      "git_commit_delta"
    ]
  },
  "authoritative_source_boundaries": [
    {
      "source_id": "beads_active_delta",
      "source_class": "beads_active_closed_delta",
      "authoritative_for": [
        "open_issue_count",
        "in_progress_issue_count",
        "ready_issue_count",
        "stale_in_progress_candidates",
        "dependency_blocked_count"
      ],
      "progress_slo_boundary": "May read issue status, assignee, priority, dependency, and age deltas; must not claim, close, reopen, reprioritize, tombstone, or rewrite Beads."
    },
    {
      "source_id": "beads_closed_delta",
      "source_class": "beads_active_closed_delta",
      "authoritative_for": [
        "closed_issue_count",
        "closed_priority_mix",
        "closed_with_commit_reference_count",
        "recent_closeout_reasons"
      ],
      "progress_slo_boundary": "May classify useful progress only when closeout evidence is present; must not treat raw closure count as sufficient proof of shipped work."
    },
    {
      "source_id": "git_commit_delta",
      "source_class": "git_commit_delta",
      "authoritative_for": [
        "commit_count",
        "pushed_commit_count",
        "changed_path_count",
        "commit_to_bead_linkage",
        "dirty_worktree_scope"
      ],
      "progress_slo_boundary": "May correlate commits with Beads and evidence; must not stash, reset, clean, checkout, commit, push, or rewrite git state."
    },
    {
      "source_id": "rch_posture",
      "source_class": "rch_and_validation_broker_posture",
      "authoritative_for": [
        "worker_availability",
        "queue_depth",
        "fail_open_local_risk",
        "remote_offload_health"
      ],
      "progress_slo_boundary": "May classify build_saturated or recommend backoff; must not schedule, cancel, prioritize, or hide RCH jobs."
    },
    {
      "source_id": "validation_broker_posture",
      "source_class": "rch_and_validation_broker_posture",
      "authoritative_for": [
        "admission_decision",
        "active_slots",
        "duplicate_gate_opportunities",
        "stale_validation_slots",
        "scratch_budget_status"
      ],
      "progress_slo_boundary": "May consume advisory admission posture; must not replace the validation broker, cargo gates, UBS, ledger reconciliation, or CI."
    },
    {
      "source_id": "agent_mail_health",
      "source_class": "agent_mail_health",
      "authoritative_for": [
        "mail_health_status",
        "reservation_readiness",
        "message_readiness",
        "schema_corruption",
        "coordination_degraded_reason"
      ],
      "progress_slo_boundary": "May report coordination_degraded and soft-lock risk; must not infer permission to collide, reserve files, send mail, acknowledge mail, or mutate Agent Mail state."
    },
    {
      "source_id": "operator_runpack_summary",
      "source_class": "runpack_autopilot_context_summaries",
      "authoritative_for": [
        "operator_next_actions",
        "runpack_status",
        "source_status_coverage",
        "redaction_posture"
      ],
      "progress_slo_boundary": "May project progress posture into operator handoff; must not replace runpack generation or make release, benchmark, throughput, or drop-in claims."
    },
    {
      "source_id": "swarm_autopilot_summary",
      "source_class": "runpack_autopilot_context_summaries",
      "authoritative_for": [
        "selected_action",
        "input_pack_status",
        "decision_gate_status",
        "planner_suppressed_claims"
      ],
      "progress_slo_boundary": "May compare progress posture with autopilot recommendations; must not select, launch, or mutate an autopilot plan."
    },
    {
      "source_id": "context_intelligence_summary",
      "source_class": "runpack_autopilot_context_summaries",
      "authoritative_for": [
        "context_graph_status",
        "bundle_status",
        "cache_status",
        "redaction_summary",
        "prompt_injection_posture"
      ],
      "progress_slo_boundary": "May read advisory context posture; must not replace direct source inspection, code review, or context-intelligence gates."
    },
    {
      "source_id": "operator_time_window",
      "source_class": "operator_provided_time_window",
      "authoritative_for": [
        "window_start_utc",
        "window_end_utc",
        "minimum_window_seconds",
        "comparison_baseline"
      ],
      "progress_slo_boundary": "May bound the observation interval; must not silently widen, narrow, or invent the requested window when inputs are malformed."
    }
  ],
  "status_contract": {
    "required_fields": [
      "status",
      "confidence",
      "reason_ids",
      "source_statuses",
      "progress_metrics",
      "saturation_summary",
      "suppressed_claims"
    ],
    "allowed_statuses": [
      "progressing",
      "quiet_blocked",
      "coordination_degraded",
      "build_saturated",
      "stalled",
      "converged_no_open_work",
      "malformed_source_degraded",
      "insufficient_evidence_degraded"
    ],
    "required_reason_ids": [
      "PROGRESS-SLO-BEAD-CLOSEOUT",
      "PROGRESS-SLO-GIT-COMMIT-DELTA",
      "PROGRESS-SLO-NO-READY-WORK",
      "PROGRESS-SLO-STALE-IN-PROGRESS",
      "PROGRESS-SLO-AGENT-MAIL-DEGRADED",
      "PROGRESS-SLO-RCH-SATURATED",
      "PROGRESS-SLO-VALIDATION-BROKER-SATURATED",
      "PROGRESS-SLO-MALFORMED-SOURCE",
      "PROGRESS-SLO-MISSING-AUTHORITY",
      "PROGRESS-SLO-CONVERGED-NO-OPEN-WORK"
    ],
    "progressing_requires": [
      "at_least_one_recent_closed_bead_or_commit_linked_to_bead",
      "operator_time_window_available",
      "required_authority_sources_available",
      "no_malformed_required_source",
      "suppressed_claims_do_not_include_progressing"
    ],
    "stalled_requires": [
      "active_work_without_recent_closeout_or_commit",
      "stale_in_progress_evidence_or_repeated_validation_failures",
      "reason_id_PROGRESS_SLO_STALE_IN_PROGRESS_or_missing_authority_degraded"
    ],
    "converged_no_open_work_requires": [
      "zero_open_beads",
      "zero_in_progress_beads",
      "recent_graph_validation_or_explicit_empty_queue_observation",
      "no_malformed_required_source"
    ]
  },
  "progress_metrics_contract": {
    "required_fields": [
      "closed_beads",
      "open_beads",
      "in_progress_beads",
      "ready_beads",
      "commits",
      "pushed_commits",
      "validation_passes",
      "validation_failures",
      "agent_mail_health",
      "rch_queue_depth",
      "stale_in_progress_candidates"
    ],
    "counter_policy": "Counters are advisory aggregates over the declared time_window. Missing or malformed counters must degrade the status instead of defaulting to zero.",
    "useful_progress_policy": "Useful progress requires evidence from Beads and git or validation artifacts. File churn, Agent Mail chatter, RCH queue activity, or repeated failed validations alone must not count as useful progress."
  },
  "saturation_contract": {
    "required_fields": [
      "coordination_saturation",
      "build_saturation",
      "validation_saturation",
      "queue_convergence",
      "recommended_operator_posture"
    ],
    "allowed_dimension_statuses": [
      "green",
      "yellow",
      "red",
      "unknown"
    ],
    "recommended_operator_postures": [
      "continue_current_swarm",
      "narrow_validation_scope",
      "backoff_heavy_cargo",
      "repair_coordination_tooling",
      "generate_new_beads",
      "handoff_for_human_triage"
    ],
    "claim_boundary": "Saturation dimensions are operational hints only. They are not release performance, benchmark, throughput, or drop-in certification evidence."
  },
  "redaction_policy": {
    "fail_closed": true,
    "allowed_redaction_states": [
      "none",
      "redacted",
      "sensitive_omitted",
      "unsafe_to_emit"
    ],
    "forbidden_raw_fields": [
      "prompt_body",
      "agent_mail_body",
      "api_key",
      "token",
      "credential",
      "secret",
      "raw_home_path",
      "raw_tmp_path",
      "session_transcript"
    ],
    "required_redaction_summary_fields": [
      "redacted_count",
      "omitted_count",
      "unsafe_to_emit_count",
      "suppressed_claims"
    ]
  },
  "fail_closed_policy": {
    "fail_closed": true,
    "malformed_required_source_status": "malformed_source_degraded",
    "missing_required_authority_status": "insufficient_evidence_degraded",
    "coordination_tooling_corrupt_status": "coordination_degraded",
    "build_queue_saturated_status": "build_saturated",
    "green_status_forbidden_when": [
      "operator_time_window_missing_or_malformed",
      "beads_delta_missing_or_malformed",
      "git_delta_missing_or_malformed",
      "required_source_freshness_unknown",
      "redaction_state_unsafe_to_emit",
      "source_statuses_empty"
    ]
  },
  "progress_slo_guards": {
    "read_only": true,
    "no_live_mutation": true,
    "advisory_only": true,
    "disallowed_live_actions": [
      "claim_bead",
      "close_bead",
      "reopen_bead",
      "create_bead",
      "reprioritize_bead",
      "send_agent_mail",
      "acknowledge_agent_mail",
      "reserve_file",
      "release_file",
      "start_rch_job",
      "cancel_rch_job",
      "git_commit",
      "git_push",
      "git_pull_rebase",
      "write_source_file",
      "delete_file"
    ]
  },
  "downstream_dependencies": {
    "unblocked_beads": [
      "bd-wzri8.2",
      "bd-wzri8.8"
    ],
    "blocked_until_contract_exists": [
      "deterministic_progress_slo_evaluator",
      "read_only_swarm_progress_cli",
      "doctor_and_runpack_projection",
      "no_mock_progress_slo_e2e",
      "large_host_progress_slo_budgets",
      "operator_workflow_docs",
      "progress_slo_closeout_gate"
    ]
  },
  "contract_tests": {
    "required_test_file": "tests/swarm_progress_slo_contract.rs",
    "focused_command": "rch exec -- cargo test --test swarm_progress_slo_contract -- --nocapture",
    "must_prove": [
      "contract JSON is parseable",
      "schema and bead linkage are stable",
      "source inventory covers Beads active/closed deltas, git commit delta, RCH and validation broker posture, Agent Mail health, runpack/autopilot/context summaries, and operator time window",
      "missing or malformed required sources fail closed to degraded statuses",
      "progressing status cannot replace Beads, Agent Mail, RCH, validation broker, Doctor, runpacks, context intelligence, UBS, CI, release gates, or direct operator judgment",
      "guards are read-only and forbid live mutations"
    ]
  }
}
