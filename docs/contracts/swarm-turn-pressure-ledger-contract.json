{
  "schema": "pi.swarm.turn_pressure_ledger_contract.v1",
  "ledger_schema": "pi.swarm.turn_pressure_ledger.v1",
  "purpose": "operator_diagnostic_not_release_performance_claim",
  "allowed_statuses": [
    "ok",
    "watch",
    "pressured",
    "blocked"
  ],
  "required_top_level_keys": [
    "schema",
    "generated_at",
    "status",
    "purpose",
    "turn_window",
    "dimensions",
    "pressure_events",
    "summary",
    "guards"
  ],
  "required_dimension_ids": [
    "normal_turn_baseline",
    "tool_artifact_spillover",
    "compaction_admission",
    "provider_routing",
    "tui_frame_budget",
    "session_write_amplification"
  ],
  "required_dimension_fields": [
    "id",
    "status",
    "signal",
    "evidence_paths",
    "metrics",
    "recommendation"
  ],
  "required_event_fields": [
    "dimension_id",
    "status",
    "signal",
    "evidence_paths",
    "recommendation"
  ],
  "required_true_guards": [
    "advisory_only",
    "not_release_claim_evidence",
    "no_embedded_bodies",
    "does_not_replace_source_runtime_metrics",
    "stable_for_action_planner_consumption"
  ],
  "required_replay_scenarios": [
    "normal_turn",
    "large_tool_artifact_spillover",
    "compaction_admission_pressure",
    "provider_reroute",
    "tui_frame_budget_pressure",
    "session_write_backpressure"
  ],
  "must_requirements": [
    {
      "id": "TURN-PRESSURE-MUST-001",
      "description": "The ledger is an operator diagnostic artifact and is not release, benchmark, or drop-in claim evidence.",
      "validated_by": [
        "purpose",
        "guards.not_release_claim_evidence"
      ]
    },
    {
      "id": "TURN-PRESSURE-MUST-002",
      "description": "Every output includes the six stable dimensions needed by later action planners: normal baseline, tool spillover, compaction, provider routing, TUI frame budget, and session write amplification.",
      "validated_by": [
        "required_dimension_ids"
      ]
    },
    {
      "id": "TURN-PRESSURE-MUST-003",
      "description": "Pressure events carry only derived metrics and evidence paths, never raw prompt text or full tool payload bodies.",
      "validated_by": [
        "required_event_fields",
        "guards.no_embedded_bodies"
      ]
    },
    {
      "id": "TURN-PRESSURE-MUST-004",
      "description": "Self-test replay covers normal turns, large tool artifacts, compaction pressure, provider reroutes, TUI frame pressure, and session write backpressure.",
      "validated_by": [
        "required_replay_scenarios"
      ]
    }
  ]
}
