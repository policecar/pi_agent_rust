{
  "schema": "pi.swarm.operator_runpack_contract.v1",
  "runpack_schema": "pi.swarm.operator_runpack.v1",
  "scorecard_schema": "pi.swarm.safety_scorecard.v1",
  "autopilot_handoff_schema": "pi.swarm.autopilot_handoff.v1",
  "purpose": "operator_handoff_not_release_performance_claim",
  "minimum_redacted_count": 1,
  "required_top_level_keys": [
    "schema",
    "generated_at",
    "status",
    "purpose",
    "source_statuses",
    "doctor_swarm",
    "beads",
    "agent_mail",
    "rch_admission",
    "evidence_readiness",
    "git_state",
    "activity_digest",
    "smoke_harness",
    "bottleneck_attribution",
    "swarm_scale_safety_scorecard",
    "redaction_summary",
    "operator_next_actions"
  ],
  "required_source_ids": [
    "doctor_swarm",
    "claim_readiness",
    "smoke_harness",
    "activity_digest",
    "cargo_admission",
    "beads",
    "git_status"
  ],
  "optional_source_ids": [
    "tail_latency",
    "flight_recorder",
    "host_preflight",
    "hostcall_swarm_profile",
    "session_recovery_swarm_profile",
    "rpc_swarm_e2e",
    "rch_artifact_sync"
  ],
  "required_summary_paths": [
    "doctor_swarm.agent_mail_build_slots",
    "beads.stale",
    "agent_mail.build_slots",
    "rch_admission.decision",
    "rch_admission.queue_forecast.recommended_action",
    "evidence_readiness.overall_status",
    "git_state.dirty",
    "activity_digest.evidence_pointers",
    "smoke_harness.artifact_manifest",
    "smoke_harness.scenario_statuses",
    "bottleneck_attribution.schema",
    "bottleneck_attribution.status",
    "bottleneck_attribution.surface_coverage",
    "bottleneck_attribution.input_classification",
    "bottleneck_attribution.bottlenecks",
    "bottleneck_attribution.operator_notes",
    "swarm_scale_safety_scorecard.overall_status",
    "swarm_scale_safety_scorecard.dimensions",
    "swarm_scale_safety_scorecard.green_requires_all_required_evidence",
    "redaction_summary.redacted_count",
    "operator_next_actions"
  ],
  "optional_summary_paths": [
    "tail_latency.schema",
    "tail_latency.telemetry_enabled",
    "tail_latency.redaction_summary",
    "tail_latency.metrics",
    "autopilot_handoff.schema",
    "autopilot_handoff.input_pack.schema",
    "autopilot_handoff.input_pack.status",
    "autopilot_handoff.plan.schema",
    "autopilot_handoff.plan.status",
    "autopilot_handoff.plan.selected_action",
    "autopilot_handoff.plan.actions",
    "autopilot_handoff.source_provenance.source_statuses",
    "autopilot_handoff.source_provenance.command_count"
  ],
  "required_source_status_fields": [
    "size_bytes",
    "sha256"
  ],
  "required_redacted_fields": [
    "doctor_swarm.findings[0].detail"
  ],
  "required_next_action_fragments": [
    "Review stale in-progress Beads",
    "Treat cargo/RCH admission",
    "Back off heavy cargo validation",
    "Use activity-digest saturation evidence",
    "Account for dirty files",
    "Review degraded swarm-scale safety scorecard"
  ],
  "allowed_statuses": [
    "ready",
    "degraded"
  ],
  "allowed_scorecard_statuses": [
    "ready",
    "degraded"
  ],
  "allowed_dimension_statuses": [
    "green",
    "yellow",
    "red"
  ],
  "required_scorecard_dimensions": [
    "coordination_health",
    "cargo_rch_posture",
    "perf_evidence_freshness",
    "dirty_worktree_tolerance",
    "stalled_bead_hygiene",
    "resource_governor_readiness",
    "bottleneck_attribution_coverage",
    "test_coverage"
  ],
  "must_requirements": [
    {
      "id": "RUNPACK-MUST-001",
      "description": "Runpack output declares the operator runpack schema and the non-release-claim purpose.",
      "validated_by": [
        "schema",
        "purpose"
      ]
    },
    {
      "id": "RUNPACK-MUST-002",
      "description": "Runpack output carries every required top-level operator summary section.",
      "validated_by": [
        "required_top_level_keys"
      ]
    },
    {
      "id": "RUNPACK-MUST-003",
      "description": "Runpack source status coverage names every upstream evidence source the wrapper may aggregate.",
      "validated_by": [
        "required_source_ids"
      ]
    },
    {
      "id": "RUNPACK-MUST-004",
      "description": "Runpack summaries preserve actionable paths for doctor, Beads, Agent Mail, RCH admission, evidence readiness, git state, activity digest, smoke harness, bottleneck attribution, redaction, and next actions.",
      "validated_by": [
        "required_summary_paths"
      ]
    },
    {
      "id": "RUNPACK-MUST-004A",
      "description": "Runpack source statuses carry deterministic file size and SHA-256 fingerprints for every provided source artifact.",
      "validated_by": [
        "required_source_status_fields"
      ]
    },
    {
      "id": "RUNPACK-MUST-005",
      "description": "Runpack redaction evidence proves sensitive fixture content was removed before the handoff bundle is emitted.",
      "validated_by": [
        "minimum_redacted_count",
        "required_redacted_fields"
      ]
    },
    {
      "id": "RUNPACK-MUST-006",
      "description": "Runpack next actions include operator-facing remediation text for stale beads, cargo/RCH admission, activity saturation, and dirty git state.",
      "validated_by": [
        "required_next_action_fragments"
      ]
    },
    {
      "id": "RUNPACK-MUST-007",
      "description": "Runpack output includes a swarm-scale safety scorecard with coordination health, cargo/RCH posture, perf evidence freshness, dirty-worktree tolerance, stalled-Bead hygiene, resource-governor readiness, bottleneck-attribution coverage, and test coverage dimensions; every green dimension must retain required source IDs and evidence paths.",
      "validated_by": [
        "scorecard_schema",
        "required_scorecard_dimensions",
        "allowed_dimension_statuses"
      ]
    },
    {
      "id": "RUNPACK-MUST-008",
      "description": "When optional operator tail-latency telemetry is supplied, the runpack projects the redaction-safe timing-only summary into the handoff bundle and source statuses.",
      "validated_by": [
        "optional_source_ids",
        "optional_summary_paths"
      ]
    },
    {
      "id": "RUNPACK-MUST-009",
      "description": "Runpack output includes a diagnostic-only bottleneck-attribution dashboard covering provider streaming, local tools, extension hostcalls, persistence, RCH sync/retrieval, queue pressure, and cgroup/NUMA context; stale optional diagnostics degrade the dashboard and schema mismatches fail closed.",
      "validated_by": [
        "required_summary_paths",
        "optional_source_ids",
        "required_scorecard_dimensions"
      ]
    },
    {
      "id": "RUNPACK-MUST-010",
      "description": "When companion autopilot input-pack and plan artifacts are requested, the runpack projects a diagnostic autopilot handoff summary that cites the autopilot schemas, selected dry-run action, artifact paths, and source provenance without replacing the authoritative source artifacts.",
      "validated_by": [
        "autopilot_handoff_schema",
        "optional_summary_paths"
      ]
    }
  ]
}
