  "scorecard_schema": "pi.swarm.safety_scorecard.v1",
  "autopilot_handoff_schema": "pi.swarm.autopilot_handoff.v1",
  "purpose": "operator_handoff_not_release_performance_claim",
  "minimum_redacted_count": 1,
