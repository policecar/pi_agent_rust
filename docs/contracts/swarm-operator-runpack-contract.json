  "required_source_status_fields": [
    "size_bytes",
    "sha256"
  ],
  "required_redacted_fields": [
    "doctor_swarm.findings[0].detail"
  ],
  "required_next_action_fragments": [
    "Review stale in-progress Beads",
    "Treat cargo/RCH admission",
    "Inspect remote validation proof ledger",
    "Back off heavy cargo validation",
    "Use activity-digest saturation evidence",
    "Review turn pressure ledger",
    "Account for dirty files",
    "Review degraded swarm-scale safety scorecard"
  ],
  "allowed_statuses": [
    "ready",
    "degraded"
  ],
  "allowed_scorecard_statuses": [
    "ready",
    "degraded"
  ],
  "allowed_dimension_statuses": [
    "green",
    "yellow",
    "red"
  ],
  "required_scorecard_dimensions": [
    "coordination_health",
    "cargo_rch_posture",
    "perf_evidence_freshness",
    "dirty_worktree_tolerance",
    "stalled_bead_hygiene",
    "resource_governor_readiness",
    "bottleneck_attribution_coverage",
    "test_coverage"
  ],
  "must_requirements": [
    {
      "id": "RUNPACK-MUST-001",
      "description": "Runpack output declares the operator runpack schema and the non-release-claim purpose.",
      "validated_by": [
        "schema",
        "purpose"
      ]
    },
    {
      "id": "RUNPACK-MUST-002",
      "description": "Runpack output carries every required top-level operator summary section.",
      "validated_by": [
        "required_top_level_keys"
      ]
    },
    {
      "id": "RUNPACK-MUST-003",
      "description": "Runpack source status coverage names every upstream evidence source the wrapper may aggregate.",
      "validated_by": [
        "required_source_ids"
      ]
    },
    {
      "id": "RUNPACK-MUST-004",
      "description": "Runpack summaries preserve actionable paths for doctor, Beads, Agent Mail, RCH admission, remote validation proof, evidence readiness, git state, activity digest, smoke harness, bottleneck attribution, redaction, and next actions.",
      "validated_by": [
        "required_summary_paths"
      ]
    },
    {
      "id": "RUNPACK-MUST-004A",
      "description": "Runpack source statuses carry deterministic file size and SHA-256 fingerprints for every provided source artifact.",
      "validated_by": [
        "required_source_status_fields"
      ]
    },
    {
      "id": "RUNPACK-MUST-005",
      "description": "Runpack redaction evidence proves sensitive fixture content was removed before the handoff bundle is emitted.",
      "validated_by": [
        "minimum_redacted_count",
        "required_redacted_fields"
      ]
    },
    {
      "id": "RUNPACK-MUST-006",
      "description": "Runpack next actions include operator-facing remediation text for stale beads, cargo/RCH admission, remote validation proof ledger review, activity saturation, and dirty git state.",
      "validated_by": [
        "required_next_action_fragments"
      ]
    },
    {
      "id": "RUNPACK-MUST-007",
      "description": "Runpack output includes a swarm-scale safety scorecard with coordination health, cargo/RCH posture, perf evidence freshness, dirty-worktree tolerance, stalled-Bead hygiene, resource-governor readiness, bottleneck-attribution coverage, and test coverage dimensions; every green dimension must retain required source IDs and evidence paths.",
      "validated_by": [
        "scorecard_schema",
        "required_scorecard_dimensions",
        "allowed_dimension_statuses"
      ]
    },
    {
      "id": "RUNPACK-MUST-007A",
      "description": "Runpack output includes a per-turn pressure ledger that correlates prompt, tool artifact, provider, TUI, and session write pressure without embedding raw prompt or tool payload bodies.",
      "validated_by": [
        "turn_pressure_ledger.schema",
        "turn_pressure_ledger.dimensions",
        "turn_pressure_ledger.guards"
      ]
    },
    {
      "id": "RUNPACK-MUST-008",
      "description": "When optional operator tail-latency telemetry is supplied, the runpack projects the redaction-safe timing-only summary into the handoff bundle and source statuses.",
      "validated_by": [
        "optional_source_ids",
        "optional_summary_paths"
      ]
    },
    {
      "id": "RUNPACK-MUST-009",
      "description": "Runpack output includes a diagnostic-only bottleneck-attribution dashboard covering provider streaming, local tools, extension hostcalls, persistence, RCH sync/retrieval, queue pressure, and cgroup/NUMA context; stale optional diagnostics degrade the dashboard and schema mismatches fail closed.",
      "validated_by": [
        "required_summary_paths",
        "optional_source_ids",
        "required_scorecard_dimensions"
      ]
    },
    {
      "id": "RUNPACK-MUST-010",
      "description": "When companion autopilot input-pack and plan artifacts are requested, the runpack projects a diagnostic autopilot handoff summary that cites the autopilot schemas, selected dry-run action, artifact paths, and source provenance without replacing the authoritative source artifacts.",
      "validated_by": [
        "autopilot_handoff_schema",
        "optional_summary_paths"
      ]
    },
    {
      "id": "RUNPACK-MUST-011",
      "description": "When an optional swarm replay preview artifact is supplied, the runpack projects the comparison summary and recommended policy without replacing replay traces, policy reports, or source evidence.",
      "validated_by": [
        "optional_source_ids",
        "optional_summary_paths"
      ]
    },
    {
      "id": "RUNPACK-MUST-012",
      "description": "When validation-broker posture is supplied directly or through Doctor, the runpack projects source status, slot counts, stale warnings, duplicate-gate opportunities, and advisory guards without treating them as CI, RCH, Beads, Agent Mail, or release-claim authority.",
      "validated_by": [
        "optional_source_ids",
        "optional_summary_paths"
      ]
    },
    {
      "id": "RUNPACK-MUST-013",
      "description": "Runpack output embeds the remote-validation proof ledger so operators can inspect whether each cargo/RCH gate ran remotely, refused local fallback, or carried artifact retrieval warnings before closing beads.",
      "validated_by": [
        "required_top_level_keys",
        "required_summary_paths"
      ]
    }
  ]
}
